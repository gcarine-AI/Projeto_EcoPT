{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,            /* ESSENCIAL: Permite que o TS leia os teus ficheiros .js */
    "checkJs": false,           /* Opcional: Se queres que o TS aponte erros nos teus .js */
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,            /* Manter false se o teu JS não tiver tipos, para não dar erros chatos */
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",                 /* Se os teus ficheiros estiverem numa pasta src */
    "controllers/**/*",         /* As tuas pastas de lógica */
    "routes/**/*",
    "middleware/**/*",
    "app.js",
    "server.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}